  "description": "Local-first control plane: helmd hub daemon + helm.html UI",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/test.mjs",
