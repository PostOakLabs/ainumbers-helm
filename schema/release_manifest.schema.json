{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainumbers.co/helm/schema/release_manifest.schema.json",
  "title": "Helm release manifest (HELM-H8, D10)",
  "description": "The in-toto Statement signed by the release signing key over a tagged Helm release's artifacts (SEA binaries per platform + packaging manifests). Subject entries are the artifacts by relative dist/ path; predicate carries the release version and platform list. Wrapped in a DSSE envelope (schema/envelope.schema.json) as release-manifest.dsse.json; this file validates the decoded statement written alongside it as release-manifest.json.",
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "subjectEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest", "size"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": { "const": "https://in-toto.io/Statement/v1" },
    "subject": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/subjectEntry" } },
    "predicateType": { "const": "https://ainumbers.co/helm/attestation/v1#release-manifest" },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "node_version", "platforms"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "node_version": { "type": "string", "minLength": 1 },
        "platforms": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
